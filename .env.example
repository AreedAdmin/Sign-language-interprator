# ─────────────────────────────────────────────────────────────
# .env.example  —  ASL Real-time Interpreter
# ─────────────────────────────────────────────────────────────
# This file IS committed to Git so teammates know which variables
# to fill in.  Copy it to .env and replace the placeholder values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Camera ───────────────────────────────────────────────────
CAMERA_INDEX=0
FRAME_WIDTH=640
FRAME_HEIGHT=480

# ── MediaPipe tuning ─────────────────────────────────────────
MIN_DETECTION_CONFIDENCE=0.6
MIN_TRACKING_CONFIDENCE=0.5
FRAME_SKIP=0

# ── LLM / AI API keys ────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Gradio ───────────────────────────────────────────────────
GRADIO_PORT=7860
GRADIO_SHARE=False

# ── TTS ──────────────────────────────────────────────────────
TTS_RATE=150
TTS_VOLUME=0.9

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
